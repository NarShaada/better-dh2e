{{!-- templates/chat/cast-card.hbs --}}
<div class="bdh-card bdh-cast-card {{#if success}}ok{{else}}fail{{/if}}">
  <header class="bdh-card-head">
    {{casterName}} {{#if success}}casts{{else}}fails to cast{{/if}} <b>{{powerName}}</b>
  </header>
  <div class="bdh-card-stats">
    <div class="bdh-stat"><b>{{target}}</b><span>Target</span></div>
    <div class="bdh-stat"><b>{{modifierLabel}}</b><span>Modifier</span></div>
    <div class="bdh-stat rolled"><b>{{roll}}</b><span>Rolled</span></div>
  </div>
  <div class="bdh-card-line quals">{{powerTypeLabel}} &middot; {{focusLabel}} &middot; {{prLabel}}</div>
  <div class="bdh-card-result {{#if success}}ok{{else}}fail{{/if}}">
    {{#if success}}Manifested{{else}}Failure{{/if}}
    {{#if degrees}}<span class="bdh-dos-pips">{{#times degrees}}<i></i>{{/times}}</span>{{/if}}
    <span class="deg">{{degrees}} {{#if success}}Degrees of Success{{else}}Degrees of Failure{{/if}}</span>
    {{#if dosBonus}}<span class="bdh-fate-note">+{{dosBonus}} DoS &middot; Fate</span>{{/if}}
  </div>
  {{#if phenTriggered}}
    <div class="bdh-phenomena">
      Psychic Phenomena: d100 {{phenRoll}}{{#if phenMod}} {{phenSign}}{{phenMod}}{{/if}} = <b>{{phenTotal}}</b>
      {{#if perilRoll}} — <b>Perils of the Warp!</b> d100 {{perilRoll}}{{/if}}
    </div>
  {{/if}}
  {{#if daemonicNote}}<div class="bdh-note">{{daemonicNote}}</div>{{/if}}
  {{#if opposed}}
    <div class="bdh-card-actions"><button type="button" data-bdh="castResist">Resist</button></div>
  {{/if}}
  {{!-- isAttack region: hits + Evade/Roll Damage buttons (routes through attack pipeline) --}}
  {{#if isAttack}}
    {{#if qualityLabels}}<div class="bdh-card-line bdh-quals">Qualities: {{qualityLabels}}</div>{{/if}}
    {{#if hits.length}}
      <ul class="bdh-hits">
        {{#each hits}}<li><span class="n">{{inc @index}}</span><span class="loc">{{label}}</span></li>{{/each}}
      </ul>
      <div class="bdh-card-actions">
        <button type="button" class="bdh-btn primary" data-bdh="rollDamage">Roll Damage</button>
        <button type="button" class="bdh-btn" data-bdh="evade">Evade</button>
      </div>
    {{/if}}
  {{/if}}
</div>
