<div class="bdh-card bdh-damage-card">
  <div class="bdh-card-head">{{weaponName}} — Damage ({{damageType}}, Pen {{penetration}})</div>
  <ol class="bdh-hits">{{#each hits}}<li>{{label}}: <span class="bdh-dmg-break">{{{breakdown}}}</span> — <b>{{total}}</b>{{#if rf}} <span class="bdh-rf">☠ Righteous Fury!</span>{{/if}}</li>{{/each}}</ol>
  {{#if damageNotes}}<div class="bdh-card-line bdh-qnote">{{damageNotes}}</div>{{/if}}
  {{#if shocking}}<div class="bdh-card-line">⚡ Shocking — Toughness test or Stunned: <button type="button" data-bdh="shockTest">Toughness Test</button></div>{{/if}}
  {{#if concussive}}<div class="bdh-card-line">⚡ Concussive ({{concussive}}) — Toughness test or Stunned: <button type="button" data-bdh="concussiveTest">Toughness Test</button></div>{{/if}}
  {{#if flame}}<div class="bdh-card-line">🔥 Flame — Agility test or set on fire: <button type="button" data-bdh="flameTest">Agility Test</button></div>{{/if}}
  {{#if hallucinogenic}}<div class="bdh-card-line">☣ Hallucinogenic ({{hallucinogenic}}) — Toughness test or Hallucinogen table: <button type="button" data-bdh="hallucinogenicTest">Toughness Test</button></div>{{/if}}
  {{#if snare}}<div class="bdh-card-line">🕸 Snare ({{snare}}) — Agility test or Immobilised: <button type="button" data-bdh="snareTest">Agility Test</button></div>{{/if}}
  {{#if canApply}}<div class="bdh-card-actions"><button type="button" data-bdh="applyDamage">Apply Damage → {{targetName}}</button></div>{{/if}}
</div>
